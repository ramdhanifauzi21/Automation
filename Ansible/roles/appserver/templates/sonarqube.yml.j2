services:
  sonarqube:
    image: sonarqube:community
    container_name: sonarqube
    restart: unless-stopped
    user: "1000:1000"
    environment:
      SONAR_JDBC_URL: jdbc:postgresql://{{ ip_priv_db }}:{{ db_port }}/sonarqube
      SONAR_JDBC_USERNAME: sonar
      SONAR_JDBC_PASSWORD: sonar
    ports:
      - "9000:9000"
    volumes:
      - /home/{{ username }}/sonarqube/data:/opt/sonarqube/data
      - /home/{{ username }}/sonarqube/logs:/opt/sonarqube/logs
      - /home/{{ username }}/sonarqube/extensions:/opt/sonarqube/extensions
