services:
  db:
    image: postgres:15
    container_name: postgresql
    restart: always
    environment:
      POSTGRES_DB: {{ db_name }}
      POSTGRES_USER: {{ db_user }}
      POSTGRES_PASSWORD: {{ db_password }}
      POSTGRES_HOST_AUTH_METHOD: md5
    command: postgres -c listen_addresses='*'
    ports:
      - "{{ db_port }}:5432"
    volumes:
      - ./data:/var/lib/postgresql/data
