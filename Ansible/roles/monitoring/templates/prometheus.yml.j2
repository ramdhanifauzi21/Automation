global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['{{ ip_priv_db }}:9090']

  - job_name: 'node-exporter-gateway'
    static_configs:
      - targets: ['{{ ip_priv_gateway }}:9100']
        labels:
          instance: 'fauzi-gateway'

  - job_name: 'node-exporter-app'
    static_configs:
      - targets: ['{{ ip_priv_app }}:9100']
        labels:
          instance: 'fauzi-app'

  - job_name: 'node-exporter-database'
    static_configs:
      - targets: ['{{ ip_priv_db }}:9100']
        labels:
          instance: 'fauzi-database'

  - job_name: 'cadvisor-gateway'
    static_configs:
      - targets: ['{{ ip_priv_gateway }}:8080']
        labels:
          instance: 'fauzi-gateway'

  - job_name: 'cadvisor-app'
    static_configs:
      - targets: ['{{ ip_priv_app }}:8080']
        labels:
          instance: 'fauzi-app'

  - job_name: 'cadvisor-database'
    static_configs:
      - targets: ['{{ ip_priv_db }}:8080']
        labels:
          instance: 'fauzi-database'
